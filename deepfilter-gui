#!/usr/bin/env bash
# deepfilter-gui — Launch the DeepFilterNet GUI without manually activating the venv.

SCRIPT_PATH="$(readlink -f "${BASH_SOURCE[0]}")"
PROJECT_DIR="$(dirname "$SCRIPT_PATH")"

VENV_LOCAL="$PROJECT_DIR/.venv/bin/python"

if [ -f "$VENV_LOCAL" ]; then
    PYTHON="$VENV_LOCAL"
else
    echo "Error: No virtual environment found at $VENV_LOCAL"
    echo "Please run the setup steps first."
    exit 1
fi

# Add repo root to PYTHONPATH so 'gui' package is importable
export PYTHONPATH="$REPO_ROOT${PYTHONPATH:+:$PYTHONPATH}"

exec "$PYTHON" -m gui.main "$@"
